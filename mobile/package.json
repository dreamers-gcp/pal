{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "start:lan:dev-client": "expo start --lan --dev-client",
    "start:lan": "expo start --lan",
    "start:lan:go": "expo start --lan --go",
    "start:tunnel": "expo start --tunnel",
    "start:tunnel:go": "expo start --tunnel --go",
    "start:tunnel:clear": "expo start --tunnel --go -c",
    "start:clear": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "eas:build:ios:dev": "npx eas-cli@latest build --platform ios --profile development",
    "eas:build:ios:preview": "npx eas-cli@latest build --platform ios --profile preview",
    "eas:build:ios": "npx eas-cli@latest build --platform ios --profile production",
    "eas:build:android:dev": "npx eas-cli@latest build --platform android --profile development",
    "eas:build:android:preview": "npx eas-cli@latest build --platform android --profile preview",
    "eas:build:android": "npx eas-cli@latest build --platform android --profile production",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@supabase/supabase-js": "^2.103.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-ble-advertiser": "0.0.17",
    "react-native-ble-plx": "^3.5.1",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "patch-package": "^8.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
